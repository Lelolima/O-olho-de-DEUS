# Variáveis de Ambiente - Template
# Copie para .env e preencha os valores
#
# Geração de segredos:
#   JWT_SECRET: python -c "import secrets; print(secrets.token_hex(32))"
#   ENCRYPTION_KEY: python setup_secure_install.py (gera automaticamente)

# ============================================
# SEGURANÇA E AUTENTICAÇÃO
# ============================================

# JWT Secret para autenticação (obrigatório em produção)
# Gere com: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=sua-chave-secreta-aleatoria-aqui

# Chave de criptografia Fernet (base64, 32 bytes)
# Gere com: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# ============================================
# BANCO DE DADOS
# ============================================

# PostgreSQL (produção)
# Crie o banco: CREATE DATABASE olho_de_deus;
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/olho_de_deus

# SQLite (desenvolvimento/testes)
# USE_SQLITE=true desativa PostgreSQL e usa SQLite local
USE_SQLITE=false

# ============================================
# TIMESTAMP AUTHORITY (TSA)
# ============================================

# TSA para carimbo de tempo RFC 3161
# Opções:
#   - https://freetsa.org/tsr (gratuita, sem auth)
#   - http://timestamp.digicert.com
#   - http://timestamp.globalsign.com/tsa/r6advanced1
TSA_URL=https://freetsa.org/tsr

# ============================================
# ARMAZENAMENTO DE EVIDÊNCIAS
# ============================================

# Armazenamento local (desenvolvimento)
EVIDENCE_DIR=./evidence

# AWS S3 (produção)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=olho-de-deus-evidence
AWS_REGION=us-east-1

# ============================================
# NOTIFICAÇÕES
# ============================================

# Webhook para alertas críticos
WEBHOOK_URL=https://api.example.com/alerts

# SMTP para envio de emails
SMTP_USER=usuario@example.com
SMTP_PASS=sua-senha-aqui
SMTP_SERVER=smtp.example.com
SMTP_PORT=587
SMTP_TLS=true

# ============================================
# LOGGING E DEBUG
# ============================================

# Nível de logging: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Debug mode (não usar em produção)
DEBUG=false

# ============================================
# API CONFIGURAÇÃO
# ============================================

# Host e porta da API
API_HOST=0.0.0.0
API_PORT=8000

# CORS origins (separado por vírgulas)
CORS_ORIGINS=http://localhost:3000,http://localhost:8000